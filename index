<script>
// ===== KONFIGURASI =====
const LINK_PREFIX = "https://mibenglish.github.io/eps";
const LINK_SUFFIX = ".html";

// ===== DATA KURIKULUM =====
const seasons = [
    {
        title: "Musim 1: Awal Kebangkitan",
        desc: "Fondasi otak dan kosakata dasar untuk komunikasi sederhana.",
        themes: [
            { name: "The Cognitive Reset", count: 10 },
            { name: "The Survival Kit", count: 20 },
            { name: "Present Reality & Syntax", count: 30 },
            { name: "Functional Communication", count: 40 }
        ]
    },
    {
        title: "Musim 2: Arsitek Kata",
        desc: "Struktur kalimat dan logika waktu (tenses).",
        themes: [
            { name: "The Time Continuum", count: 20 },
            { name: "Syntactic Expansion", count: 30 },
            { name: "Descriptive Capabilities", count: 30 },
            { name: "Practical Application", count: 20 }
        ]
    },
    {
        title: "Musim 3: Konektor",
        desc: "Kalimat kompleks dan sopan santun sosial.",
        themes: [
            { name: "Perfect Tenses", count: 30 },
            { name: "Conjunctions & Linkers", count: 30 },
            { name: "Modals of Nuance", count: 20 },
            { name: "Social Dynamics", count: 20 }
        ]
    },
    {
        title: "Musim 4: The Analyst",
        desc: "Analisa informasi, berpikir kritis, komunikasi profesional.",
        themes: [
            { name: "Passive Construction", count: 30 },
            { name: "Complex Conditionals", count: 30 },
            { name: "Reported Speech", count: 20 },
            { name: "Professional Intro", count: 20 }
        ]
    },
    {
        title: "Musim 5: The Diplomat",
        desc: "Soft skills, negosiasi, dan ekspresi idiomatik.",
        themes: [
            { name: "Corporate Communication", count: 30 },
            { name: "Idioms & Phrasals", count: 30 },
            { name: "Advanced Listening", count: 20 },
            { name: "Persuasion", count: 20 }
        ]
    },
    {
        title: "Musim 6: The Academic",
        desc: "Tingkat akademik: menulis esai, debat, dan analisa.",
        themes: [
            { name: "Advanced Grammar", count: 30 },
            { name: "Writing Mastery", count: 30 },
            { name: "Critical Reading", count: 20 },
            { name: "Debate", count: 20 }
        ]
    },
    {
        title: "Musim 7: The Executive",
        desc: "Bahasa untuk pemimpin: strategi bisnis dan kepemimpinan.",
        themes: [
            { name: "Leadership Language", count: 30 },
            { name: "Strategy & Negotiation", count: 30 },
            { name: "Crisis Management", count: 20 },
            { name: "Executive Presence", count: 20 }
        ]
    },
    {
        title: "Musim 8: The Specialist",
        desc: "Bahasa teknis: Kedokteran, Teknik, IT, dan Kreatif.",
        themes: [
            { name: "STEM English", count: 20 },
            { name: "Medical & Health", count: 20 },
            { name: "Tech & IT", count: 20 },
            { name: "Creative Industry", count: 40 }
        ]
    },
    {
        title: "Musim 9: The Globalist",
        desc: "Kecerdasan budaya global, humor, dan networking.",
        themes: [
            { name: "Cultural Nuance", count: 30 },
            { name: "Literary Devices", count: 30 },
            { name: "Networking Mastery", count: 20 },
            { name: "Storytelling", count: 20 }
        ]
    },
    {
        title: "Musim 10: The Polymath",
        desc: "Tahap penyempurnaan: filologi dan legacy.",
        themes: [
            { name: "Perfectionist Grammar", count: 30 },
            { name: "Linguistics for Leaders", count: 30 },
            { name: "Thought Leadership", count: 20 },
            { name: "The Final Steps", count: 20 }
        ]
    }
];

// =====================================================
// ARRAY EPISODE - SIAP DIISI JUDUL ASLI
// =====================================================
// Format: episodeTitles[nomorEpisode] = "Judul Episode";
// Contoh: episodeTitles[1] = "Pengenalan: Cara Otak Mempelajari Bahasa";
// Episode yang tidak ada di array akan tampil sebagai "Episode X"

const episodeTitles = {
    // Contoh beberapa judul (hapus dan ganti dengan judul asli)
    1: "Pengenalan: Cara Otak Mempelajari Bahasa",
    2: "Phonemes: Suara Dasar Bahasa Inggris",
    3: "Vowel Sounds: Huruf Vokal Pendek",
    100: "Milestone: Review 100 Episode Pertama",
    500: "Mid-Curriculum: Dari Dasar ke Menengah",
    1000: "Grand Finale: Dari Learner menjadi Master"
    // ... tambah judul sesuai kebutuhan
};
// =====================================================

// State
let currentSeason = 0;
let currentPage = 1;
let perPage = 50;
let searchQuery = '';
let allEpisodes = [];

// Build episode array untuk season tertentu
function buildEpisodeArray(seasonIndex) {
    const episodes = [];
    let epNum = 1;
    
    for (let s = 0; s < seasons.length; s++) {
        const season = seasons[s];
        for (const theme of season.themes) {
            for (let i = 0; i < theme.count; i++) {
                const episode = {
                    num: epNum,
                    title: episodeTitles[epNum] || `Episode ${epNum}`,
                    theme: theme.name,
                    season: s
                };
                
                if (s === seasonIndex) {
                    episodes.push(episode);
                }
                epNum++;
            }
        }
    }
    
    return episodes;
}

// Get theme for episode number
function getEpisodeTheme(epNum) {
    let current = 1;
    for (const season of seasons) {
        for (const theme of season.themes) {
            if (epNum < current + theme.count) {
                return theme.name;
            }
            current += theme.count;
        }
    }
    return "";
}

// DOM Elements
const navTabs = document.getElementById('navTabs');
const seasonTitle = document.getElementById('seasonTitle');
const seasonDesc = document.getElementById('seasonDesc');
const episodeRange = document.getElementById('episodeRange');
const episodeGrid = document.getElementById('episodeGrid');
const pagination = document.getElementById('pagination');
const pageInfo = document.getElementById('pageInfo');
const searchInput = document.getElementById('searchInput');
const perPageSelect = document.getElementById('perPageSelect');

// Render Navigation Tabs
seasons.forEach((s, i) => {
    const btn = document.createElement('button');
    btn.className = 'tab-btn' + (i === 0 ? ' active' : '');
    btn.textContent = s.title.split(':')[0];
    btn.onclick = () => selectSeason(i);
    navTabs.appendChild(btn);
});

// Select Season
function selectSeason(index) {
    currentSeason = index;
    currentPage = 1;
    searchQuery = '';
    searchInput.value = '';
    
    // Update tabs
    document.querySelectorAll('.tab-btn').forEach((b, i) => {
        b.classList.toggle('active', i === index);
    });
    
    // Update header
    const season = seasons[index];
    seasonTitle.textContent = season.title;
    seasonDesc.textContent = season.desc;
    
    // Build episodes
    allEpisodes = buildEpisodeArray(index);
    
    // Calculate episode range
    let startEp = 1;
    for (let i = 0; i < index; i++) {
        for (const t of seasons[i].themes) {
            startEp += t.count;
        }
    }
    const endEp = startEp + allEpisodes.length - 1;
    episodeRange.textContent = `Episode ${startEp} - ${endEp}`;
    
    renderEpisodes();
}

// Render Episodes
function renderEpisodes() {
    const filtered = searchQuery
        ? allEpisodes.filter(ep => 
            ep.title.toLowerCase().includes(searchQuery) ||
            ep.num.toString().includes(searchQuery) ||
            ep.theme.toLowerCase().includes(searchQuery)
          )
        : allEpisodes;
    
    const totalPages = Math.ceil(filtered.length / perPage);
    if (currentPage > totalPages) currentPage = Math.max(1, totalPages);
    
    const start = (currentPage - 1) * perPage;
    const pageEpisodes = filtered.slice(start, start + perPage);
    
    // Render grid
    if (pageEpisodes.length === 0) {
        episodeGrid.innerHTML = `
            <div class="empty-state" style="grid-column: 1/-1;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <p>Tidak ada episode yang ditemukan.</p>
            </div>
        `;
    } else {
        episodeGrid.innerHTML = pageEpisodes.map(ep => `
            <a href="${LINK_PREFIX}${ep.num}${LINK_SUFFIX}" class="ep-card">
                <div class="ep-num">${ep.num}</div>
                <div class="ep-info">
                    <div class="ep-title">${ep.title}</div>
                    <div class="ep-theme">${ep.theme}</div>
                </div>
                <div class="ep-arrow">→</div>
            </a>
        `).join('');
    }
    
    // Render pagination
    renderPagination(totalPages, filtered.length);
    
    // Page info
    if (filtered.length > 0) {
        pageInfo.textContent = `Menampilkan ${start + 1}-${Math.min(start + perPage, filtered.length)} dari ${filtered.length} episode`;
    } else {
        pageInfo.textContent = '';
    }
}

// Render Pagination
function renderPagination(totalPages, totalItems) {
    if (totalPages <= 1) {
        pagination.innerHTML = '';
        return;
    }
    
    let html = '';
    
    // Prev button
    html += `<button class="page-btn" onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>←</button>`;
    
    // Page numbers
    const maxVisible = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        html += `<button class="page-btn" onclick="goToPage(1)">1</button>`;
        if (startPage > 2) html += `<span class="page-dots">...</span>`;
    }
    
    for (let i = startPage; i <= endPage; i++) {
        html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) html += `<span class="page-dots">...</span>`;
        html += `<button class="page-btn" onclick="goToPage(${totalPages})">${totalPages}</button>`;
    }
    
    // Next button
    html += `<button class="page-btn" onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>→</button>`;
    
    pagination.innerHTML = html;
}

// Go to page
function goToPage(page) {
    currentPage = page;
    renderEpisodes();
    document.getElementById('seasonHeader').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Search handler
let searchTimeout;
searchInput.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        searchQuery = e.target.value.toLowerCase().trim();
        currentPage = 1;
        renderEpisodes();
    }, 300);
});

// Per page handler
perPageSelect.addEventListener('change', (e) => {
    perPage = parseInt(e.target.value);
    currentPage = 1;
    renderEpisodes();
});

// Initialize
selectSeason(0);
</script>

