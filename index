<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mibenglish - 1000 Langkah Mahir Bahasa Inggris</title>
    
    <meta name="description" content="Metode belajar bahasa Inggris menyenangkan seperti jalan-jalan di hutan. 1000 episode lengkap dari dasar hingga mahir.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://mibenglish.github.io/" />

    <style>
        :root {
            --bg-page: #F8FAF9;
            --bg-card: #FFFFFF;
            --primary: #0D4F3C;
            --primary-light: #1A7A5E;
            --secondary: #2D9B6A;
            --accent: #B8F4D8;
            --text-main: #1A2F26;
            --text-sub: #5C7A6E;
            --border: #E2EDE8;
            --radius: 12px;
            --shadow-sm: 0 1px 3px rgba(13, 79, 60, 0.06);
            --shadow: 0 4px 16px rgba(13, 79, 60, 0.08);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            background: var(--bg-page);
            color: var(--text-main);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Header */
        header {
            background: white;
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-inner {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .brand-logo {
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .brand-logo span { color: var(--secondary); }

        .header-stats {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            font-size: 0.85rem;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--text-sub);
        }

        .stat-item strong {
            color: var(--primary);
            font-weight: 700;
        }

        /* Navigation Tabs */
        .nav-tabs {
            background: white;
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .nav-tabs-inner {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            padding: 0.75rem 1rem;
            gap: 8px;
        }

        .tab-btn {
            flex-shrink: 0;
            padding: 0.6rem 1.2rem;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-sub);
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .tab-btn:hover {
            border-color: var(--secondary);
            color: var(--primary);
        }

        .tab-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        /* Main Content */
        main {
            max-width: 1000px;
            margin: 0 auto;
            padding: 1.5rem 1rem 3rem;
        }

        /* Season Header */
        .season-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            padding: 1.75rem 2rem;
            border-radius: var(--radius);
            margin-bottom: 1.5rem;
            position: relative;
            overflow: hidden;
        }

        .season-header::before {
            content: "";
            position: absolute;
            top: -50%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .season-header h1 {
            font-size: 1.4rem;
            margin-bottom: 0.4rem;
            position: relative;
        }

        .season-header p {
            font-size: 0.9rem;
            opacity: 0.85;
            position: relative;
        }

        .season-meta {
            display: flex;
            gap: 1.5rem;
            margin-top: 1rem;
            font-size: 0.8rem;
            opacity: 0.9;
        }

        .season-meta span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Controls Bar */
        .controls-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 200px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.75rem;
            border: 1px solid var(--border);
            border-radius: 50px;
            font-size: 0.9rem;
            background: white;
            transition: all 0.2s;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 3px rgba(45, 155, 106, 0.1);
        }

        .search-box svg {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-sub);
            pointer-events: none;
        }

        .per-page-select {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .per-page-select label {
            font-size: 0.85rem;
            color: var(--text-sub);
        }

        .per-page-select select {
            padding: 0.6rem 1rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.85rem;
            background: white;
            cursor: pointer;
        }

        /* Episode Grid */
        .episode-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 12px;
        }

        .ep-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            text-decoration: none;
            color: inherit;
            transition: all 0.2s ease;
        }

        .ep-card:hover {
            border-color: var(--secondary);
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .ep-num {
            flex-shrink: 0;
            width: 44px;
            height: 44px;
            background: var(--bg-page);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.95rem;
            color: var(--primary);
            transition: all 0.2s;
        }

        .ep-card:hover .ep-num {
            background: var(--accent);
        }

        .ep-info {
            flex: 1;
            min-width: 0;
        }

        .ep-title {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--text-main);
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ep-theme {
            font-size: 0.8rem;
            color: var(--text-sub);
        }

        .ep-arrow {
            flex-shrink: 0;
            width: 28px;
            height: 28px;
            background: var(--bg-page);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-sub);
            font-size: 0.75rem;
            transition: all 0.2s;
        }

        .ep-card:hover .ep-arrow {
            background: var(--primary);
            color: white;
        }

        /* Pagination */
        .pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-sub);
            cursor: pointer;
            transition: all 0.2s;
        }

        .page-btn:hover:not(:disabled) {
            border-color: var(--secondary);
            color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .page-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .page-dots {
            padding: 0 8px;
            color: var(--text-sub);
        }

        .page-info {
            font-size: 0.85rem;
            color: var(--text-sub);
            text-align: center;
            margin-top: 1rem;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-sub);
        }

        .empty-state svg {
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        /* Footer */
        footer {
            background: white;
            border-top: 1px solid var(--border);
            padding: 2.5rem 1rem 1.5rem;
            margin-top: 3rem;
        }

        .footer-inner {
            max-width: 1000px;
            margin: 0 auto;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 12px 24px;
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .footer-links a {
            font-size: 0.85rem;
            color: var(--text-sub);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .footer-links a:hover { color: var(--primary); }

        .socials {
            display: flex;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .social-btn {
            padding: 8px 16px;
            background: var(--bg-page);
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-main);
            text-decoration: none;
            transition: all 0.2s;
        }

        .social-btn:hover {
            background: var(--primary);
            color: white;
        }

        .copyright {
            text-align: center;
            font-size: 0.75rem;
            color: #999;
            margin-top: 1rem;
        }

        /* Responsive */
        @media (max-width: 600px) {
            .header-stats { display: none; }
            .season-header { padding: 1.25rem 1.5rem; }
            .season-header h1 { font-size: 1.2rem; }
            .season-meta { flex-direction: column; gap: 0.5rem; }
            .episode-grid { grid-template-columns: 1fr; }
            .controls-bar { flex-direction: column; }
            .per-page-select { justify-content: flex-end; }
        }
    </style>
</head>
<body>

    <header>
        <div class="header-inner">
            <a href="https://mibenglish.github.io/" class="brand-logo">mib<span>english</span></a>
            <div class="header-stats">
                <div class="stat-item">
                    <strong>1000</strong> Episode
                </div>
