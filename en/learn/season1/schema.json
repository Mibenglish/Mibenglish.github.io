{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mibenglish Episode Data Schema",
  "description": "Schema untuk file JSON episode Mibenglish. Gunakan schema ini untuk memvalidasi data episode sebelum publish.",
  "type": "object",
  "required": ["meta", "url", "article", "tableOfContents", "sections", "faq", "related", "quiz", "nextEpisode"],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Metadata untuk SEO dan social media",
      "required": ["description", "keywords", "ogTitle", "ogDescription", "ogImage", "twitterTitle", "twitterDescription", "twitterImage", "pageTitle", "publishedDate", "modifiedDate"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Meta description untuk SEO (150-160 karakter)",
          "maxLength": 160
        },
        "keywords": {
          "type": "array",
          "description": "Keywords untuk SEO",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 10
        },
        "ogTitle": {
          "type": "string",
          "description": "Open Graph title (untuk Facebook, LinkedIn)"
        },
        "ogDescription": {
          "type": "string",
          "description": "Open Graph description"
        },
        "ogImage": {
          "type": "string",
          "format": "uri",
          "description": "URL gambar untuk Open Graph (1200x630px)"
        },
        "twitterTitle": {
          "type": "string",
          "description": "Twitter card title"
        },
        "twitterDescription": {
          "type": "string",
          "description": "Twitter card description"
        },
        "twitterImage": {
          "type": "string",
          "format": "uri",
          "description": "URL gambar untuk Twitter card"
        },
        "pageTitle": {
          "type": "string",
          "description": "Title tag halaman (untuk browser tab)"
        },
        "publishedDate": {
          "type": "string",
          "format": "date-time",
          "description": "Tanggal publish dalam format ISO 8601"
        },
        "modifiedDate": {
          "type": "string",
          "format": "date",
          "description": "Tanggal terakhir diubah"
        }
      }
    },
    "url": {
      "type": "object",
      "description": "URL halaman",
      "required": ["canonical", "english", "indonesian"],
      "properties": {
        "canonical": {
          "type": "string",
          "format": "uri",
          "description": "URL canonical halaman"
        },
        "english": {
          "type": "string",
          "format": "uri",
          "description": "URL versi English"
        },
        "indonesian": {
          "type": "string",
          "format": "uri",
          "description": "URL versi Indonesian"
        }
      }
    },
    "article": {
      "type": "object",
      "description": "Informasi artikel",
      "required": ["episode", "title", "titleShort", "subtitle", "level", "readTime", "date"],
      "properties": {
        "episode": {
          "type": "integer",
          "description": "Nomor episode",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "description": "Judul lengkap episode"
        },
        "titleShort": {
          "type": "string",
          "description": "Judul singkat untuk breadcrumb"
        },
        "subtitle": {
          "type": "string",
          "description": "Subtitle episode"
        },
        "level": {
          "type": "string",
          "description": "Level kesulitan (e.g., 'Level A0-A1 (Absolute Beginner Foundation)')"
        },
        "readTime": {
          "type": "integer",
          "description": "Estimasi waktu baca dalam menit",
          "minimum": 5,
          "maximum": 30
        },
        "date": {
          "type": "string",
          "description": "Tanggal publish dalam format readable"
        }
      }
    },
    "tableOfContents": {
      "type": "array",
      "description": "Daftar isi",
      "items": { "type": "string" },
      "minItems": 3,
      "maxItems": 7
    },
    "sections": {
      "type": "array",
      "description": "Konten sections artikel",
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Judul section"
          },
          "content": {
            "type": "array",
            "description": "Array konten items",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["paragraph", "heading", "list", "highlight", "example", "diagram"],
                  "description": "Tipe konten"
                },
                "text": {
                  "type": "string",
                  "description": "Teks untuk paragraph atau heading"
                },
                "ordered": {
                  "type": "boolean",
                  "description": "Untuk list: true = ordered (ol), false = unordered (ul)"
                },
                "items": {
                  "type": "array",
                  "description": "Items untuk list",
                  "items": { "type": "string" }
                },
                "style": {
                  "type": "string",
                  "enum": ["", "warning", "success", "info"],
                  "description": "Style untuk highlight box"
                },
                "label": {
                  "type": "string",
                  "description": "Label untuk highlight atau example"
                },
                "sentence": {
                  "type": "string",
                  "description": "Kalimat contoh untuk example box"
                },
                "translation": {
                  "type": "string",
                  "description": "Terjemahan atau penjelasan untuk example"
                },
                "title": {
                  "type": "string",
                  "description": "Judul untuk diagram"
                },
                "content": {
                  "type": "string",
                  "description": "Konten untuk diagram"
                }
              }
            }
          }
        }
      },
      "minItems": 3
    },
    "faq": {
      "type": "array",
      "description": "FAQ items",
      "items": {
        "type": "object",
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "string",
            "description": "Pertanyaan FAQ"
          },
          "answer": {
            "type": "string",
            "description": "Jawaban FAQ"
          }
        }
      },
      "minItems": 3,
      "maxItems": 6
    },
    "related": {
      "type": "array",
      "description": "Episode terkait",
      "items": {
        "type": "object",
        "required": ["episode", "title", "url"],
        "properties": {
          "episode": {
            "type": "integer",
            "description": "Nomor episode"
          },
          "title": {
            "type": "string",
            "description": "Judul episode"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL episode"
          }
        }
      },
      "minItems": 2,
      "maxItems": 5
    },
    "quiz": {
      "type": "array",
      "description": "Quiz questions",
      "items": {
        "type": "object",
        "required": ["question", "options", "correct", "explanation"],
        "properties": {
          "question": {
            "type": "string",
            "description": "Pertanyaan quiz"
          },
          "options": {
            "type": "array",
            "description": "Pilihan jawaban",
            "items": { "type": "string" },
            "minItems": 4,
            "maxItems": 4
          },
          "correct": {
            "type": "integer",
            "description": "Index jawaban benar (0-3)",
            "minimum": 0,
            "maximum": 3
          },
          "explanation": {
            "type": "string",
            "description": "Penjelasan jawaban"
          }
        }
      },
      "minItems": 5,
      "maxItems": 5
    },
    "nextEpisode": {
      "type": "object",
      "description": "Episode selanjutnya",
      "required": ["episode", "title", "subtitle", "url"],
      "properties": {
        "episode": {
          "type": "integer",
          "description": "Nomor episode"
        },
        "title": {
          "type": "string",
          "description": "Judul episode"
        },
        "subtitle": {
          "type": "string",
          "description": "Subtitle episode"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL episode"
        }
      }
    }
  }
}
